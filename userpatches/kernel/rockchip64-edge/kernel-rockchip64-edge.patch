From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: John Doe <john.doe@somewhere.on.planet>
Date: Wed, 13 Dec 2023 16:22:11 +0000
Subject: Enable uart0 in rk3328-roc-cc.dts

Signed-off-by: John Doe <john.doe@somewhere.on.planet>
---
 arch/arm64/boot/dts/rockchip/rk3328-roc-cc.dts | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/arch/arm64/boot/dts/rockchip/rk3328-roc-cc.dts b/arch/arm64/boot/dts/rockchip/rk3328-roc-cc.dts
index aa22a0c222..51bfb81ba9 100644
--- a/arch/arm64/boot/dts/rockchip/rk3328-roc-cc.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3328-roc-cc.dts
@@ -6,11 +6,11 @@
 /dts-v1/;
 #include "rk3328-dram-renegade-timing.dtsi"
 #include "rk3328.dtsi"
 
 / {
-	model = "Firefly roc-rk3328-cc";
+	model = "ZNP-K1";
 	compatible = "firefly,roc-rk3328-cc", "rockchip,rk3328";
 
 	aliases {
 		mmc0 = &sdmmc;
 		mmc1 = &emmc;
@@ -353,6 +353,20 @@
 	status = "okay";
 };

+&uart0 {
+	pinctrl-0 = <&uart0_xfer &uart0_cts>;
+	status = "okay";
+};
+
 &uart2 {
 	status = "okay";
 };

+&pinctrl {
+	uart0_xfer: uart0-xfer {
+		rockchip,pins = <0 RK_PA0 RK_FUNC_UART0_TX>, <0 RK_PA1 RK_FUNC_UART0_RX>;
+	};
+	uart0_cts: uart0-cts {
+		rockchip,pins = <0 RK_PA3 RK_FUNC_UART0_CTS>;
+	};
+};
+
-- 
