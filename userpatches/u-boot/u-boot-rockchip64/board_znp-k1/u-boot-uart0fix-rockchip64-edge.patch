From: John Doe <john.doe@somewhere.on.planet>
Date: Wed, 13 Dec 2023 16:22:11 +0000
Subject: Patching u-boot rockchip64 files arch/arm/dts/rk3328-roc-cc.dts

Signed-off-by: John Doe <john.doe@somewhere.on.planet>
---
 arch/arm/dts/rk3328-roc-cc.dts | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/arch/arm/dts/rk3328-roc-cc.dts b/arch/arm/dts/rk3328-roc-cc.dts
index aa22a0c222..51bfb81ba9 100644
--- a/arch/arm/dts/rk3328-roc-cc.dts
+++ b/arch/arm/dts/rk3328-roc-cc.dts
@@ -352,10 +352,18 @@
 
 &u2phy_otg {
 	status = "okay";
 };
 
+&uart0 {
+	pinctrl-0 = <&uart0_xfer &uart0_cts>;
+	status = "okay";
+};
+
 &uart2 {
 	status = "okay";
 };
 
+&pinctrl {
+	uart0_xfer: uart0-xfer {
+		rockchip,pins = <0 RK_PA0 RK_FUNC_UART0_TX>, <0 RK_PA1 RK_FUNC_UART0_RX>;
+	};
+	uart0_cts: uart0-cts {
+		rockchip,pins = <0 RK_PA3 RK_FUNC_UART0_CTS>;
+	};
+};
+
 &usb20_otg {
 	dr_mode = "host";
 	status = "okay";
